# 是否删除console
VITE_DROP_CONSOLE = false

# 是否开启 mock 服务
VITE_USE_MOCK = false

# 权限路由模式: static | dynamic
# - static: 静态权限路由，在客户端生成
# - dynamic: 动态权限路由，在服务端生成，通过接口获取权限路由
VITE_AUTH_ROUTE_MODE = 'static'

# 开发环境跨域代理，可以配置多个，请注意不要换行
# VITE_PROXY = [["/api","http://localhost:5173"]]
# VITE_PROXY = [["/appApi","http://localhost:3000"],["/upload","http://localhost:3000/upload"]]

# 本地环境接口地址
# 如果没有跨域问题，直接在这里配置即可
VITE_SERVICE_BASE_URL = ''
