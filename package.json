{
  "name": "galaxy-admin-react",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "description": "使用 React + TS 构建的后台管理系统",
  "author": {
    "name": "sankeyangshu",
    "email": "sankeyangshu@gmail.com",
    "url": "https://github.com/sankeyangshu"
  },
  "license": "MIT",
  "homepage": "https://github.com/sankeyangshu/galaxy-admin-react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sankeyangshu/galaxy-admin-react.git"
  },
  "bugs": {
    "url": "https://github.com/sankeyangshu/galaxy-admin-react/issues"
  },
  "keywords": [
    "react",
    "template",
    "typescript",
    "axios",
    "react-router",
    "antd",
    "i18n-react",
    "zustand",
    "unocss"
  ],
  "engines": {
    "node": "^18.18.0 || >=20.0.0",
    "pnpm": ">=8.15.4"
  },
  "scripts": {
    "dev": "vite",
    "build:dev": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "build:test": "vite build --mode test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "preview": "vite preview",
    "clean:cache": "rimraf node_modules/.cache/ && rimraf node_modules/.vite",
    "clean:lib": "rimraf node_modules",
    "release": "bumpp",
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "antd": "^5.24.9",
    "dayjs": "^1.11.13",
    "i18next": "^25.1.1",
    "i18next-browser-languagedetector": "^8.1.0",
    "motion": "^12.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.1",
    "react-router": "^7.5.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@sankeyangshu/eslint-config": "^1.0.0",
    "@types/node": "^22.15.14",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@unocss/eslint-plugin": "^66.1.0",
    "@unocss/preset-rem-to-px": "^66.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "bumpp": "^10.1.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "less": "^4.3.0",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.3",
    "rimraf": "^6.0.1",
    "simple-git-hooks": "^2.13.0",
    "typescript": "~5.8.3",
    "unocss": "^66.1.0",
    "vite": "^6.3.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-restart": "^0.4.2",
    "vite-plugin-svg-icons": "^2.0.1",
    "vitest": "^3.1.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx --no-install commitlint --edit $1"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
