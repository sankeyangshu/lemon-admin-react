{
  "name": "lemon-admin-react",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "description": "An admin system template based on the React ecosystem",
  "author": {
    "name": "sankeyangshu",
    "email": "sankeyangshu@gmail.com",
    "url": "https://github.com/sankeyangshu"
  },
  "license": "MIT",
  "homepage": "https://github.com/sankeyangshu/lemon-admin-react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sankeyangshu/lemon-admin-react.git"
  },
  "bugs": {
    "url": "https://github.com/sankeyangshu/lemon-admin-react/issues"
  },
  "keywords": [
    "react",
    "template",
    "typescript",
    "@tanstack/react-router",
    "@tanstack/react-query",
    "i18n-react",
    "zustand",
    "tailwindcss v4",
    "iconify"
  ],
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.5.0"
  },
  "scripts": {
    "dev": "vite",
    "build:dev": "tsc && vite build --mode development",
    "build:prod": "tsc && vite build --mode production",
    "build:test": "tsc && vite build --mode test",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "clean:cache": "rimraf node_modules/.cache/ && rimraf node_modules/.vite",
    "clean:lib": "rimraf node_modules",
    "release": "bumpp",
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@reactuses/core": "^6.1.11",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.9.10",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.166.3",
    "@tanstack/react-router-devtools": "^1.166.3",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "es-toolkit": "^1.45.1",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "immer": "^11.1.4",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.6",
    "react-top-loading-bar": "^3.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@date-fns/tz": "^1.4.1",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@iconify/react": "^6.0.2",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@tanstack/eslint-plugin-router": "^1.161.4",
    "@tanstack/router-plugin": "^1.166.3",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "ansis": "^4.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.3",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "lint-staged": "^16.3.2",
    "rimraf": "^6.1.3",
    "shadcn": "^4.0.2",
    "simple-git-hooks": "^2.13.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "unplugin-svg-component": "^0.12.4",
    "vite": "^7.3.1",
    "vite-plugin-restart": "^2.0.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm typecheck && pnpm lint-staged",
    "commit-msg": "pnpm exec commitlint --edit $1"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
